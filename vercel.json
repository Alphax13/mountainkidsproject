{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    {
      "src": "/(css|js|fonts)/(.+)",
      "dest": "/$1/$2"
    },
    {
      "src": "/img/(.+)",
      "dest": "/img/$1"
    },
    {
      "src": "/uploads/(.+)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.php)$",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ]
}
