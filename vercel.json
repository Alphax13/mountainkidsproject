{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    {
      "src": "/(css|js|fonts)/(.+)",
      "dest": "/$1/$2",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(img|uploads)/(.+\\.(jpg|jpeg|png|gif|webp|svg|jfif))",
      "dest": "/$1/$2",
      "headers": {
        "Cache-Control": "public, max-age=31536000",
        "Content-Type": "image/$3"
      }
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.php"
    }
  ]
}
